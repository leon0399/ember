iously selected conversation still exists after replacement,\n    /// the selection follows it. Otherwise, selection clamps to bounds.\n    pub fn set_conversations(&mut self, conversations: Vec<Conversation>) {\n        let selected_id = self.selected().map(|c| c.public_id);\n        self.conversations = conversations;\n\n        if self.conversations.is_empty() {\n            self.state.select(None);\n            return;\n        }\n\n        // Try to follow the previously selected conversation\n        let new_index = selected_id\n            .and_then(|id| self.conversations.iter().position(|c| c.public_id == id))\n            .unwrap_or(0);\n        self.state.select(Some(new_index));\n    }\n\n    /// Sort conversations: most recent message first, no-message contacts last by created_at.\n    pub fn sort_by_recent(&mut self) {\n        let selected_id = self.selected().map(|c| c.public_id);\n\n        self.conversations.sort_by(|a, b| {\n            match (a.last_message_time, b.last_message_time) {\n                (Some(ta), Some(tb)) => tb.cmp(&ta), // descending\n                (Some(_), None) => std::cmp::Ordering::Less,\n                (None, Some(_)) => std::cmp::Ordering::Greater,\n                (None, None) => std::cmp::Ordering::Equal,\n            }\n        });\n\n        // Restore selection\n        if let Some(id) = selected_id {\n            if let Some(pos) = self.conversations.iter().position(|c| c.public_id == id) {\n                self.state.select(Some(pos));\n            }\n        }\n    }\n\n    /// Move selection up.\n    pub fn select_previous(&mut self) {\n        if self.conversations.is_empty() {\n            return;\n        }\n        let i = self.state.selected().unwrap_or(0);\n        if i > 0 {\n            self.state.select(Some(i - 1));\n        }\n    }\n\n    /// Move selection down.\n    pub fn select_next(&mut self) {\n        if self.conversations.is_empty() {\n            return;\n        }\n        let i = self.state.selected().unwrap_or(0);\n        if i < self.conversations.len() - 1 {\n            self.state.select(Some(i + 1));\n        }\n    }\n\n    /// Get the currently selected conversation, if any.\n    pub fn selected(&self) -> Option<&Conversation> {\n        self.state\n            .selected()\n            .and_then(|i| self.conversations.get(i))\n    }\n\n    /// Get a mutable reference to the selected conversation.\n    pub fn selected_mut(&mut self) -> Option<&mut Conversation> {\n        self.state\n            .selected()\n            .and_then(|i| self.conversations.get_mut(i))\n    }\n\n    /// Get the selected index (for compatibility during migration).\n    pub fn selected_index(&self) -> Option<usize> {\n        self.state.selected()\n    }\n\n    /// Get a conversation by index.\n    pub fn get(&self, index: usize) -> Option<&Conversation> {\n        self.conversations.get(index)\n    }\n\n    /// Get a mutable conversation by index.\n    pub fn get_mut(&mut self, index: usize) -> Option<&mut Conversation> {\n        self.conversations.get_mut(index)\n    }\n\n    /// Find a conversation by `PublicID`, returning its index.\n    pub fn find_by_public_id(&self, public_id: &PublicID) -> Option<usize> {\n        self.conversations\n            .iter()\n            .position(|c| c.public_id == *public_id)\n    }\n\n    /// Push a new conversation and return its index.\n    pub fn push(&mut self, conversation: Conversation) -> usize {\n        self.conversations.push(conversation);\n        let idx = self.conversations.len() - 1;\n        // Select the first conversation if nothing is selected\n        if self.state.selected().is_none() {\n            self.state.select(Some(0));\n        }\n        idx\n    }\n\n    /// Number of conversations.\n    pub fn len(&self) -> usize {\n        self.conversations.len()\n    }\n\n    /// Whether the list is empty.\n    pub fn is_empty(&self) -> bool {\n        self.conversations.is_empty()\n    }\n\n    /// Toggle between two-line and compact display.\n    pub fn toggle_display_mode(&mut self) {\n        self.display_mode = match self.display_mode {\n            DisplayMode::TwoLine => DisplayMode::Compact,\n            DisplayMode::Compact => DisplayMode::TwoLine,\n        };\n    }\n\n    /// Current display mode.\n    pub fn display_mode(&self) -> DisplayMode {\n        self.display_mode\n    }\n\n    /// Iterator over conversations.\n    pub fn iter(&self) -> std::slice::Iter<'_, Conversation> {\n        self.conversations.iter()\n    }\n}\n```\n\n- [ ] **Step 2: Add rendering method**\n\nAppend to `conversation_list.rs`:\n\n```rust\nimpl ConversationList {\n    /// Render the conversation list into the given area.\n    pub fn render(&mut self, frame: &mut Frame, area: ratatui::layout::Rect, is_focused: bool) {\n        let border_style = if is_focused {\n            Style::default().fg(Color::Cyan)\n        } else {\n            Style::default().fg(Color::DarkGray)\n        };\n\n        let title = format!(\" Conversations ({}) \", self.conversations.len());\n\n        let items: Vec<ListItem> = self\n            .conversations\n            .iter()\n            .map(|conv| self.render_item(conv, area.width.saturating_sub(2)))\n            .collect();\n\n        let list = List::new(items)\n            .block(\n                Block::default()\n                    .borders(Borders::ALL)\n                    .border_style(border_style)\n                    .title(title),\n            )\n            .highlight_style(\n                Style::default()\n                    .bg(Color::DarkGray)\n                    .add_modifier(Modifier::BOLD),\n            )\n            .highlight_symbol(\"> \");\n\n        frame.render_stateful_widget(list, area, &mut self.state);\n    }\n\n    /// Build a `ListItem` for one conversation.\n    fn render_item(&self, conv: &Conversation, width: u16) -> ListItem {\n        match self.display_mode {\n            DisplayMode::TwoLine => self.render_two_line(conv, width),\n            DisplayMode::Compact => self.render_compact(conv, width),\n        }\n    }\n\n    /// Two-line layout:\n    /// ```text\n    /// Name          ✓  2m  (3)\n    /// Hey, are you coming t...\n    /// ```\n    /// Plus a trailing blank line for separation.\n    fn render_two_line(&self, conv: &Conversation, _width: u16) -> ListItem {\n        let mut lines = vec![self.build_header_line(conv)];\n\n        // Message preview line\n        if let Some(ref msg) = conv.last_message {\n            let preview = truncate_str(msg, 40);\n            lines.push(Line::from(Span::styled(\n                format!(\"  {preview}\"),\n                Style::default().fg(Color::DarkGray),\n            )));\n        }\n\n        // Separator blank line\n        lines.push(Line::from(\"\"));\n\n        ListItem::new(lines)\n    }\n\n    /// Compact layout: single line with name, trust, time, unread.\n    fn render_compact(&self, conv: &Conversation, _width: u16) -> ListItem {\n        ListItem::new(self.build_header_line(conv))\n    }\n\n    /// Build the shared header line: `Name    ✓  2m  (3)`\n    fn build_header_line(&self, conv: &Conversation) -> Line<'static> {\n        let mut spans = vec![Span::styled(\n            conv.name.clone(),\n            Style::default().fg(Color::White),\n        )];\n\n        // Trust icon\n        let (icon, color) = trust_icon(conv.trust_level);\n        spans.push(Span::raw(\"  \"));\n        spans.push(Span::styled(icon, Style::default().fg(color)));\n\n        // Relative timestamp\n        if let Some(ts) = conv.last_message_time {\n            spans.push(Span::raw(\"  \"));\n            spans.push(Span::styled(\n                format_relative_time(ts),\n                Style::default().fg(Color::DarkGray),\n            ));\n        }\n\n        // Unread badge\n        if conv.unread_count > 0 {\n            spans.push(Span::raw(\"  \"));\n            spans.push(Span::styled(\n                format!(\"({})\", conv.unread_count),\n                Style::default()\n                    .fg(Color::Red)\n                    .add_modifier(Modifier::BOLD),\n            ));\n        }\n\n        Line::from(spans)\n    }\n}\n\n/// Trust level icon and color.\nfn trust_icon(level: TrustLevel) -> (&'static str, Color) {\n    match level {\n        TrustLevel::Stranger => (\"?\", Color::Yellow),\n        TrustLevel::Known => (\"○\", Color::DarkGray),\n        TrustLevel::Verified => (\"✓\", Color::Green),\n        TrustLevel::Trusted => (\"●\", Color::Cyan),\n    }\n}\n\n/// Format a unix timestamp as a relative time string.\n///\n/// - < 60s: `\"now\"`\n/// - < 60m: `\"Nm\"`\n/// - < 24h: `\"Nh\"`\n/// - < 7d: `\"Nd\"`\n/// - otherwise: `\"Mon DD\"` (e.g. `\"Mar 28\"`)\nfn format_relative_time(timestamp_secs: i64) -> String {\n    use std::time::{SystemTime, UNIX_EPOCH};\n\n    let now = SystemTime::now()\n        .duration_since(UNIX_EPOCH)\n        .map(|d| d.as_secs())\n        .unwrap_or(0);\n\n    #[allow(clippy::cast_sign_loss)]\n    let ts = if timestamp_secs < 0 {\n        0u64\n    } else {\n        timestamp_secs as u64\n    };\n\n    let delta = now.saturating_sub(ts);\n\n    if delta < 60 {\n        \"now\".to_string()\n    } else if delta < 3600 {\n        format!(\"{}m\", delta / 60)\n    } else if delta < 86400 {\n        format!(\"{}h\", delta / 3600)\n    } else if delta < 604_800 {\n        format!(\"{}d\", delta / 86400)\n    } else {\n        // Month DD format\n        format_month_day(ts)\n    }\n}\n\n/// Format a unix timestamp as \"Mon DD\" (e.g. \"Mar 28\").\nfn format_month_day(timestamp_secs: u64) -> String {\n    // Simple days-from-epoch calculation (no chrono dependency needed)\n    let days = timestamp_secs / 86400;\n    // Civil date from days since epoch (algorithm from Howard Hinnant)\n    let z = days + 719_468;\n    let era = z / 146_097;\n    let doe = z - era * 146_097;\n    let yoe = (doe - doe / 1460 + doe / 36524 - doe / 146_096) / 365;\n    let doy = doe - (365 * yoe + yoe / 4 - yoe / 100);\n    let mp = (5 * doy + 2) / 153;\n    let d = doy - (153 * mp + 2) / 5 + 1;\n    let m = if mp < 10 { mp + 3 } else { mp - 9 };\n\n    let month_name = match m {\n        1 => \"Jan\",\n        2 => \"Feb\",\n        3 => \"Mar\",\n        4 => \"Apr\",\n        5 => \"May\",\n        6 => \"Jun\",\n        7 => \"Jul\",\n        8 => \"Aug\",\n        9 => \"Sep\",\n        10 => \"Oct\",\n        11 => \"Nov\",\n        12 => \"Dec\",\n        _ => \"???\",\n    };\n\n    format!(\"{month_name} {d}\")\n}\n\n/// Truncate a string to `max_len` characters, appending \"...\" if truncated.\nfn truncate_str(s: &str, max_len: usize) -> String {\n    if s.len() <= max_len {\n        s.to_string()\n    } else {\n        let truncated: String = s.chars().take(max_len.saturating_sub(3)).collect();\n        format!(\"{truncated}...\")\n    }\n}\n```\n\n- [ ] **Step 3: Register the module**\n\nIn `apps/client/src/tui/mod.rs`, add:\n\n```rust\npub mod conversation_list;\n```\n\n- [ ] **Step 4: Run checks**\n\nRun: `cargo check -p client && cargo clippy -p client --all-targets -- -D warnings`\n\nExpected: PASS (the component compiles but isn't wired in yet).\n\n- [ ] **Step 5: Commit**\n\n```\nfeat(tui): add ConversationList component with ListState\n\nExtract conversation list into its own module with:\n- ListState for proper highlight/auto-scroll (fixes #169)\n- Two-line and compact display modes\n- Trust level icons (? ○ ✓ ●)\n- Relative timestamp formatting\n- Sort-by-recent-activity\n- Selection-follows-conversation on re-sort\n```\n\n---\n\n### Task 4: Wire `ConversationList` into `App`\n\n**Files:**\n\n- Modify: `apps/client/src/tui/app.rs`\n\nThis is the largest task — it replaces `conversations: Vec<Conversation>` and `selected_conversation: usize` with the new component and updates every call site.\n\n- [ ] **Step 1: Update imports and remove old `Conversation` struct**\n\nIn `apps/client/src/tui/app.rs`:\n