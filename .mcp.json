{
  "mcpServers": {
    "deepwiki": {
      "type": "http",
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "context7": {
      "command": "pnpx",
      "args": ["@upstash/context7-mcp@latest"]
    },
    "repomix": {
      "command": "pnpx",
      "args": ["repomix@latest", "--mcp"]
    },
    "gh_grep": {
      "type": "http",
      "url": "https://mcp.grep.app"
    }
  }
}
