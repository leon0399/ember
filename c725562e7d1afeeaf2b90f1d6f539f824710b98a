ring stranger (routing key not in contacts)\"\n                );\n                return;\n            }\n        };\n\n        let is_update = self.peer_index.contains_key(&peer.instance_name);\n\n        if !is_update && self.peer_index.len() >= self.max_peers {\n            warn!(\n                instance = %peer.instance_name,\n                \"Peer limit reached ({MAX_PEERS}), ignoring new peer\"\n            );\n            return;\n        }\n\n        let addr = match peer.addresses.first() {\n            Some(a) => *a,\n            None => {\n                warn!(\n                    instance = %peer.instance_name,\n                    \"No addresses in discovery event\"\n                );\n                return;\n            }\n        };\n\n        let url = format!(\"http://{}:{}\", bracket_ipv6(addr), peer.port);\n\n        let verified = match self.verify_peer_identity(&url, candidates).await {\n            Ok(Some(pubkey)) => Some(pubkey),\n            Ok(None) => {\n                debug!(\n                    instance = %peer.instance_name,\n                    \"Identity verification: no candidate matched\"\n                );\n                return;\n            }\n            Err(e) => {\n                debug!(\n                    instance = %peer.instance_name,\n                    \"Identity verification failed: {e}\"\n                );\n                return;\n            }\n        };\n\n        if is_update {\n            self.handle_update(peer, addr, &url, verified, coordinator);\n        } else {\n            self.handle_new(peer, addr, &url, verified, coordinator);\n        }\n    }\n\n    fn handle_new(\n        &mut self,\n        peer: reme_discovery::RawDiscoveredPeer,\n        addr: IpAddr,\n        url: &str,\n        verified: Option<PublicID>,\n        coordinator: &TransportCoordinator,\n    ) {\n        let config = HttpTargetConfig::ephemeral(url)\n            .with_node_pubkey_opt(verified)\n            .with_label(format!(\"lan:{}\", peer.instance_name));\n\n        let target = match HttpTarget::new(config) {\n            Ok(t) => t,\n            Err(e) => {\n                warn!(\n                    instance = %peer.instance_name,\n                    \"Failed to create HTTP target: {e}\"\n                );\n                return;\n            }\n        };\n\n        let target_id = TargetId::http(url);\n        coordinator.add_http_target(target);\n\n        info!(\n            instance = %peer.instance_name,\n            url = %url,\n            verified = verified.is_some(),\n            \"Registered discovered peer\"\n        );\n\n        self.peer_index.insert(\n            peer.instance_name,\n            PeerEntry {\n                target_id,\n                verified_identity: verified,\n                addresses: peer.addresses,\n                port: peer.port,\n            },\n        );\n    }\n\n    fn handle_update(\n        &mut self,\n        peer: reme_discovery::RawDiscoveredPeer,\n        addr: IpAddr,\n        url: &str,\n        verified: Option<PublicID>,\n        coordinator: &TransportCoordinator,\n    ) {\n        let entry = self.peer_index.get(&peer.instance_name).unwrap();\n        let old_url = format!(\n            \"http://{}:{}\",\n            bracket_ipv6(*entry.addresses.first().unwrap()),\n            entry.port\n        );\n        let address_changed = old_url != url;\n\n        if address_changed {\n            let config = HttpTargetConfig::ephemeral(url)\n                .with_node_pubkey_opt(verified)\n                .with_label(format!(\"lan:{}\", peer.instance_name));\n\n            let target = match HttpTarget::new(config) {\n                Ok(t) => t,\n                Err(e) => {\n                    warn!(\n                        instance = %peer.instance_name,\n                        \"Failed to create replacement HTTP target: {e}\"\n                    );\n                    return;\n                }\n         