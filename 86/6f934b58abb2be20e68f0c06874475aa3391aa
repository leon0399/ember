`[dev-dependencies]`:\n```toml\nasync-trait = { workspace = true }\n```\n\n## Helper functions\n\n```rust\n/// Create a bundle from pending outbox messages.\nfn export_to_bundle(messages: &[PendingMessage]) -> Vec<u8> {\n    let mut buf = Vec::new();\n    let mut writer = BundleWriter::new(&mut buf);\n    for msg in messages {\n        let envelope: OuterEnvelope = postcard::from_bytes(&msg.envelope_bytes)\n            .expect(\"Failed to deserialize envelope from outbox\");\n        let wire = WirePayload::Message(envelope);\n        let frame = wire.encode().expect(\"Failed to encode WirePayload\");\n        writer.write_frame(&frame).expect(\"Failed to write frame\");\n    }\n    writer.finish().expect(\"Failed to finish bundle\");\n    buf\n}\n\n/// Import bundle frames into a node's mailbox store.\nfn import_to_node(store: &PersistentMailboxStore, bundle_bytes: &[u8]) {\n    let reader = BundleReader::open(Cursor::new(bundle_bytes)).expect(\"Failed to open bundle\");\n    let frames = reader.read_all_verified().expect(\"Bundle checksum failed\");\n    for frame in &frames {\n        let payload = WirePayload::decode(frame).expect(\"Failed to decode frame\");\n        if let WirePayload::Message(envelope) = payload {\n            store.enqueue(envelope.routing_key, envelope).expect(\"Failed to enqueue\");\n        }\n    }\n}\n```\n\n## Test: TestServer with exposed store\n\nThe existing `TestServer` doesn't expose the store. We need a variant that does, so we can call `import_to_node` on it. Create:\n\n```rust\nstruct TestServerWithStore {\n    url: String,\n    store: Arc<PersistentMailboxStore>,\n    _handle: tokio::task::JoinHandle<()>,\n}\n```\n\nCopy the `TestServer::start()` logic but save `store` as a field. The store is created as `Arc<PersistentMailboxStore>` — clone it into both `AppState` and the struct field.\n\n## Test scenarios\n\n### 1. `test_sneakernet_happy_path`\nThe main test — full round-trip with real encryption:\n\n```rust\n#[tokio::test]\nasync fn test_sneakernet_happy_path() {\n    // 1. Create Alice (offline) and Bob identities\n    let alice_identity = Identity::generate();\n    let bob_identity = Identity::generate();\n\n    // 2. Alice prepares message for Bob (offline — NoopTransport)\n    let alice_storage = Storage::in_memory().unwrap();\n    let alice = Client::new(alice_identity.clone(), Arc::new(NoopTransport), alice_storage.clone());\n    alice.add_contact(bob_identity.public_id(), Some(\"Bob\")).unwrap();\n    \n    let prepared = alice.prepare_message(\n        bob_identity.public_id(),\n        Content::Text(TextContent { body: \"Hello from sneakernet!\".to_string() }),\n        false,\n    ).unwrap();\n\n    // 3. Export from Alice's outbox\n    let pending = alice_storage.outbox_get_pending().unwrap();\n    assert_eq!(pending.len(), 1);\n    let bundle_bytes = export_to_bundle(&pending);\n\n    // 4. Start node, import bundle\n    let server = TestServerWithStore::start().await;\n    import_to_node(&server.store, &bundle_bytes);\n\n    // 5. Bob connects to node and fetches\n    let transport = Arc::new(TransportPool::<HttpTarget>::single(server.url()).unwrap());\n    let bob_storage = Storage::in_memory().unwrap();\n    let bob = Client::new(bob_identity, transport.clone(), bob_storage);\n    bob.add_contact(alice_identity.public_id(), Some(\"Alice\")).unwrap();\n\n    // 6. Bob fetches messages via transport\n    let bob_routing_key = bob.routing_key();\n    let coordinator = test_coordinator(&transport);\n    let (mut events, _handle) = coordinator.subscribe(bob_routing_key);\n\n    let received = tokio::time::timeout(Duration::from_secs(5), async {\n        while let Some(event) = events.recv().await {\n            if let TransportEvent::Message(envelope) = event {\n                return bob.process_message(&envelope).await.ok();\n            }\n        }\n        None\n    }).await.expect(\"Timeout waiting for message\").expect(\"No message received\");\n\n    // 7. Verify\n    assert_eq!(received.message_id, prepared.outer.message_id);\n    match &received.content {\n        Content::Text(text) => assert_eq!(text.body, \"Hello from sneakernet!\"),\n        other => panic!(\"Expected Text, got {:?}\", other),\n    }\n}\n```\n\n### 2. `test_sneakernet_multiple_messages`\nAlice sends 5 messages, all arrive:\n\nSame pattern as happy path but loop `prepare_message` 5 times, export all, import, Bob fetches all 5. Verify count and content.\n\n### 3. `test_sneakernet_duplicate_import_idempotent`\nImport same bundle twice into node → Bob only sees each message once:\n\n```rust\n#[tokio::test]\nasync fn test_sneakernet_duplicate_import_idempotent() {\n    // ... Alice prepares + exports ...\n    import_to_node(&server.store, &bundle_bytes);\n    import_to_node(&server.store, &bundle_bytes); // second import — should be no-op\n    // Bob fetches — should see exactly 1 message, not 2\n}\n```\n\n### 4. `test_sneakernet_wrong_recipient_not_decryptable`\nBundle with message for Charlie, Bob imports it → message is in the node but Bob can't decrypt it (WrongRecipient error from process_message_local):\n\n```rust\n#[tokio::test]\nasync fn test_sneakernet_wrong_recipient_not_decryptable() {\n    let alice = Identity::generate();\n    let bob = Identity::generate();\n    let charlie = Identity::generate();\n\n    // Alice sends to Charlie\n    // ... prepare_message for charlie ...\n    // Export + import into node\n\n    // Bob tries to fetch — the message has charlie's routing key, so Bob's\n    // fetch (which queries by Bob's routing key) won't even return it.\n    // This verifies routing key isolation.\n}\n```\n\n### 5. `test_sneakernet_empty_bundle`\nExport with no messages → valid empty bundle → import is no-op:\n\n```rust\n#[tokio::test]\nasync fn test_sneakernet_empty_bundle() {\n    let mut buf = Vec::new();\n    let writer = BundleWriter::new(&mut buf);\n    writer.finish().unwrap(); // empty bundle, 0 frames\n\n    let server = TestServerWith