   }\n    }\n\n    /// Write a single frame (raw `WirePayload` bytes) to the bundle.\n    pub fn write_frame(&mut self, wire_payload: &[u8]) -> Result<(), BundleError> {\n        self.frame_count += 1;\n\n        let len = u32::try_from(wire_payload.len()).map_err(|_| BundleError::FrameTooLarge {\n            size: u32::MAX,\n            max: crate::MAX_FRAME_SIZE,\n        })?;\n\n        let len_bytes = len.to_le_bytes();\n        self.write_hashed(&len_bytes)?;\n        self.write_hashed(wire_payload)?;\n\n        Ok(())\n    }\n\n    /// Finalize the bundle: write the header (with correct frame count), all buffered data,\n    /// and the BLAKE3 checksum.\n    ///\n    /// Consumes `self` — the bundle cannot be written to after this.\n    pub fn finish(mut self) -> Result<(), BundleError> {\n        // If no frames were written, we still need to write the header.\n        // We need to reconstruct the full output: header + frames + checksum.\n        // But we've been hashing frame data without the header...\n        //\n        // Strategy: We deferred writing the header. Now we write it with the final count,\n        // then replay the already-written frame bytes for the checksum.\n        //\n        // Actually — simpler: we buffer frame data in `inner` and hash it.\n        // At finish, we construct the header, hash it, prepend... no, we can't prepend to a Write.\n        //\n        // Simplest correct approach: accumulate frames in a side buffer, write everything at finish.\n        // But that defeats streaming for large bundles.\n        //\n        // Best approach: write header first with count=0, write frames streaming,\n        // then seek back to patch count. But W: Write doesn't guarantee Seek.\n        //\n        // Pragmatic approach for v1: buffer frame bytes, write everything at finish.\n        // Bundles are meant for USB drives, not multi-GB streams.\n        // Actually, we already wrote frames to self.inner. Let's reconsider the design.