          "input": {
            "content": "# deny.toml тАФ cargo-deny policy for reme workspace\n# Docs: https://embarkstudios.github.io/cargo-deny/\n#\n# Policy goals (derived from WHITEPAPER.md):\n# 1. Enforce the specified crypto stack (X25519, XEdDSA, ChaCha20-Poly1305, BLAKE3)\n# 2. Prevent accidental introduction of alternative crypto backends\n# 3. Minimize metadata leakage via telemetry/analytics dependencies\n# 4. Maintain supply chain integrity (crates.io only, no unvetted git deps)\n\n[graph]\nall-features = true\n# Evaluate only the platforms we actually target.\n# Prevents false positives from UEFI-only deps (e.g., r-efi LGPL).\ntargets = [\n    \"x86_64-unknown-linux-gnu\",\n    \"aarch64-unknown-linux-gnu\",\n    \"x86_64-apple-darwin\",\n    \"aarch64-apple-darwin\",\n]\n\n# тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА\n# Advisories: fail on known vulnerabilities\n# тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА\n[advisories]\nyanked = \"warn\"\n# For a security-critical messenger, unmaintained deps deserve visibility.\nunmaintained = \"warn\"\nignore = []\n\n# тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА\n# Licenses: allowlist model (deny by default)\n# тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА\n[licenses]\nallow = [\n    \"MIT\",\n    \"Apache-2.0\",\n    \"BSD-2-Clause\",\n    \"BSD-3-Clause\",\n    \"ISC\",\n    \"Zlib\",\n    \"Unicode-3.0\",\n    \"CC0-1.0\",\n    \"BSL-1.0\",\n    \"OpenSSL\",\n    \"MPL-2.0\",\n    \"CDLA-Permissive-2.0\",\n    # BSD-1-Clause: used by fiat-crypto (curve25519-dalek dependency)\n    \"BSD-1-Clause\",\n    # MIT-0: used by aws-lc-sys, constant_time_eq, dunce\n    \"MIT-0\",\n]\nconfidence-threshold = 0.8\n\n[licenses.private]\nignore = true\n\n[[licenses.clarify]]\ncrate = \"ring\"\nexpression = \"MIT AND ISC AND OpenSSL\"\nlicense-files = [{ path = \"LICENSE\", hash = 0xbd0eed23 }]\n\n# тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА\n# Bans: prevent known-bad or duplicate crates\n# тФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФАтФА\n[bans]\nmultiple-versions = \"warn\"\nwildcards = \"deny\"\nallow-wildcard-paths = true\nhighlight = \"lowest-version\"\n\n# Crates that MUST NOT appear as direct dependencies.\n#\n# Crypto stack protection: the whitepaper specifies X25519 + XEdDSA +\n# ChaCha20-Poly1305 + BLAKE3. These bans prevent crypto stack drift by\n# blocking alternative crypto backends from being added directly.\n# Transitive usage (e.g., openssl via native-tls for TLS transport) is\n# allowed via wrappers тАФ the deny applies to direct workspace imports.\ndeny = [\n    # тФАтФА Alternative crypto backends тФАтФА\n    # We use RustCrypto + BLAKE3 + x25519-dalek. Block direct use of\n    # competing backends that would fragment the crypto surface.\n    { crate = \"sodiumoxide\", wrappers = [] },\n    { crate = \"libsodium-sys\", wrappers = [] },\n    { crate = \"boring\", wrappers = [] },\n    { crate = \"boringssl\", wrappers = [] },\n\n    # тФАтФА Telemetry / analytics тФАтФА\n    # Whitepaper ┬з3.3 goal #5: metadata minimization.\n    # These crates phone home or collect usage data.\n    { crate = \"sentry\", wrappers = [] },\n    { crate = \"sentry-core\", wrappers = [] },\n    { crate = \"datadog-apm\", wrappers = [] },\n\n    # тФАтФА Deprecated / known-bad тФАтФА\n    { crate = \"rust-crypto\", wrappers = [] },  # Unmaintained, known vulnerabilities\n]\n\n# Known-acceptable version duplicates from transitive dependency chains.\n# Each